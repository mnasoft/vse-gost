#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BUILD_DIR="${SCRIPT_DIR}/build"

mkdir -p "${BUILD_DIR}"

"${SCRIPT_DIR}/build.sh" "${BUILD_DIR}/vsegost-web"
cp "${SCRIPT_DIR}/vsegost-web.sh" "${BUILD_DIR}/"
cp "${SCRIPT_DIR}/vsegost-web-tmux.sh" "${BUILD_DIR}/"

